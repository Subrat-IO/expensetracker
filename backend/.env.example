PORT=5000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_real_mysql_password
DB_NAME=expense_tracker
DB_SSL=true
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=12h

# Uncomment this if your MySQL user authenticates over a local socket instead
# of a TCP password login.
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock
